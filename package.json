{
  "name": "onebite-ticket-display-desktop",
  "version": "3.0.0-beta.1",
  "description": "Installable desktop wrapper for the One Bite ticket display",
  "main": "main.js",
  "author": "One Bite Technology",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check:syntax": "node --check main.js && node --check preload.js && node --check app/server.js && node --check app/ticket-display.js",
    "security:audit": "npm audit --audit-level=moderate",
    "security:signatures": "npm audit signatures",
    "test:unit": "node --test test/shared-auth.test.js test/config-persistence.test.js",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:mac:local": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip -c.forceCodeSigning=false -c.mac.identity=null -c.mac.notarize=false",
    "dist:win": "electron-builder --win nsis",
    "dist:win:local": "electron-builder --win nsis -c.forceCodeSigning=false",
    "pack": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir -c.forceCodeSigning=false -c.mac.identity=null -c.mac.notarize=false",
    "security:smoke": "node scripts/security-smoke.js",
    "test": "npm run check:syntax && npm run test:unit && npm run security:smoke"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "electron": "42.6.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "ca.onebitetechnology.ticketdisplay",
    "productName": "One Bite Ticket Display",
    "forceCodeSigning": true,
    "icon": "build/icon.png",
    "afterPack": "build/after-pack.js",
    "files": [
      "main.js",
      "preload.js",
      "README.md"
    ],
    "extraResources": [
      {
        "from": "app",
        "to": "app",
        "filter": [
          "README.md",
          "WINDOWS_TV_SETUP.md",
          "index.html",
          "lib/**/*.js",
          "server.js",
          "ticket-display.css",
          "ticket-display.html",
          "ticket-display.js",
          "windows-install-tv-tasks.ps1",
          "windows-open-tv-display.bat",
          "windows-open-tv-split.bat",
          "windows-open-tv-split.ps1",
          "windows-start-server.bat",
          "!config.json",
          "!invoice-detail-cache.json",
          "!invoice-priority-cache.json",
          "!ticket-meta-cache.json"
        ]
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "generateUpdatesFilesForAllChannels": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "OneBiteTicketDisplay-${version}-Setup.${ext}"
    },
    "mac": {
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "OneBiteTicketDisplay-${version}-${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 140,
          "y": 220
        },
        {
          "x": 400,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 380,
          "type": "file",
          "path": "build/Open One Bite Ticket Display.command"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "onebitetechnology",
        "repo": "OBT-Custom-TicketDashboard"
      }
    ]
  }
}
